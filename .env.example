# MULPAZ - Ortam Degiskenleri Ornegi
#
# Bu dosyayi kopyalayip .env olarak yeniden adlandirin ve gercek degerleri girin.
# .env ASLA repoya commit edilmez (.gitignore'da .env* kurali var).
#
# cp .env.example .env

# Prisma veritaban baglantisi (SQLite - gelistirme icin yerel dosya)
DATABASE_URL="file:./mulpaz.db"

# Cron/gorev secret - /api/refresh POST endpoint'ini korur.
# UZUN, RASTGELE bir string kullanin. Ornek uretmek icin:
#   openssl rand -hex 32   veya   bun -e "console.log(crypto.randomUUID())"
CRON_SECRET="degistir-beni-guclu-rastgele-bir-anahtarla"

# Uygulamanin disaridan erisebilecegi public URL.
# Gelistirme: http://localhost:3000 | Uretim: https://market.erkanerdem.online
NEXT_PUBLIC_BASE_URL="http://localhost:3000"
